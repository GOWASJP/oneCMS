{
  "name": "onecms",
  "version": "1.0.0",
  "description": "ブラウザ完結型・インストール不要の静的サイトジェネレーター型CMS - ONE CMS",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"*.{json,md}\" index.html",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"*.{json,md}\" index.html",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "GOWAS LLC",
  "license": "Apache-2.0",
  "dependencies": {
    "@editorjs/code": "^2.9.4",
    "@editorjs/delimiter": "^1.4.2",
    "@editorjs/editorjs": "^2.31.6",
    "@editorjs/embed": "^2.7.7",
    "@editorjs/header": "^2.8.8",
    "@editorjs/image": "^2.10.3",
    "@editorjs/inline-code": "^1.5.2",
    "@editorjs/link": "^2.6.2",
    "@editorjs/nested-list": "^1.4.3",
    "@editorjs/quote": "^2.7.6",
    "@editorjs/table": "^2.4.5",
    "@fontsource/inter": "^5.2.8",
    "@tailwindcss/browser": "^4.2.2",
    "alpinejs": "^3.15.11",
    "diff-match-patch": "^1.0.5",
    "editorjs-html": "^4.0.5",
    "fflate": "^0.8.3",
    "handlebars": "^4.7.9",
    "lucide": "^1.7.0",
    "vite": "^8.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/diff-match-patch": "^1.0.36",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-alpine": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
