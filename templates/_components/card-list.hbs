<div class="card-list">
  {{#each items}}
  <article class="card">
    {{#if this.image}}<img src="{{this.image}}" alt="{{this.title}}">{{/if}}
    <div class="card-body">
      <h3><a href="{{this.url}}">{{this.title}}</a></h3>
      {{#if this.date}}<time>{{this.date}}</time>{{/if}}
      {{#if this.excerpt}}<p>{{this.excerpt}}</p>{{/if}}
    </div>
  </article>
  {{/each}}
</div>
