{{!-- フロントページ用テンプレート（サンプル） --}}
{{!-- 設定で「フロントページ」に選んだ固定ページが / にマップされ、このテンプレートで描画されます。 --}}
{{!-- フロントページも通常ページなので、本文（page.body）がそのまま入ります。 --}}
{{!-- 製作者はこのファイルを自由に書き換えてデザインを構築できます。home.hbs が無ければ page.hbs が使われます。 --}}

<article class="home">
  <div class="container">
    {{#if page.title}}<h1>{{page.title}}</h1>{{/if}}
    {{{page.body}}}
  </div>
</article>

{{!-- サンプル: 最新のお知らせ一覧（不要なら削除してください） --}}
<section class="home-news">
  <div class="container">
    <h2>お知らせ</h2>
    <ul class="news-list">
      {{#each (latestItems 'news' 5 lang)}}
        <li>
          <a href="{{url}}">
            <time datetime="{{publishedAt}}">{{formatDate publishedAt}}</time>
            <span>{{title}}</span>
          </a>
        </li>
      {{/each}}
    </ul>
    <p class="news-more"><a href="/{{#unless (eq lang defaultLang)}}{{lang}}/{{/unless}}news/">すべて見る</a></p>
  </div>
</section>
